<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Tax Invoice</title>
    <style>
        body { font-family: 'Helvetica Neue', 'Helvetica', Helvetica, Arial, sans-serif; padding: 30px; font-size: 14px; }
        .invoice-box { max-width: 800px; margin: auto; padding: 30px; border: 1px solid #eee; box-shadow: 0 0 10px rgba(0, 0, 0, .15); }
        .header { display: flex; justify-content: space-between; border-bottom: 2px solid #333; padding-bottom: 20px; margin-bottom: 20px; }
        .header h1 { margin: 0; color: #333; }
        .company-details, .customer-details { margin-bottom: 20px; }
        table { width: 100%; line-height: inherit; text-align: left; border-collapse: collapse; }
        table th, table td { padding: 8px; border-bottom: 1px solid #ddd; }
        table th { background: #eee; font-weight: bold; }
        .totals { text-align: right; margin-top: 20px; }
        .totals p { margin: 5px 0; }
        .totals p.grand-total { font-size: 18px; font-weight: bold; border-top: 2px solid #333; padding-top: 10px; }
    </style>
</head>
<body>
    <div class="invoice-box">
        <div class="header">
            <div>
                <h1>TAX INVOICE</h1>
                <p>Invoice #: <%= invoice.invoiceNumber %><br>Created: <%= new Date(invoice.date).toLocaleDateString() %></p>
            </div>
            <div>
                <h2><%= shop.name || 'Your Company' %></h2>
                <p>GSTIN: <%= shop.gstin || 'N/A' %><br>Address: <%= shop.address %></p>
            </div>
        </div>

        <div class="customer-details">
            <strong>Bill To:</strong><br>
            <%= invoice.customerDetails.name %><br>
            GSTIN: <%= invoice.customerDetails.gstin || 'N/A' %><br>
            Address: <%= invoice.customerDetails.address %>, <%= invoice.customerDetails.state %><br>
        </div>

        <table>
            <thead>
                <tr>
                    <th>Item</th>
                    <th>HSN</th>
                    <th>Qty</th>
                    <th>Price</th>
                    <th>CGST</th>
                    <th>SGST</th>
                    <th>IGST</th>
                    <th>Total</th>
                </tr>
            </thead>
            <tbody>
                <% invoice.items.forEach(function(item) { %>
                <tr>
                    <td><%= item.name %><br><small><%= item.serialNumbers ? item.serialNumbers.join(', ') : '' %></small></td>
                    <td><%= item.hsnCode %></td>
                    <td><%= item.quantity %></td>
                    <td><%= item.unitPrice %></td>
                    <td><%= item.cgstAmount %></td>
                    <td><%= item.sgstAmount %></td>
                    <td><%= item.igstAmount %></td>
                    <td><%= item.totalAmount %></td>
                </tr>
                <% }); %>
            </tbody>
        </table>

        <div class="totals">
            <p>Subtotal: <%= invoice.summary.subTotal %></p>
            <p>CGST: <%= invoice.summary.totalCGST %></p>
            <p>SGST: <%= invoice.summary.totalSGST %></p>
            <p>IGST: <%= invoice.summary.totalIGST %></p>
            <% if(invoice.tdsDetails.isTDSDeducted) { %>
                <p>TDS Deducted (<%= invoice.tdsDetails.tdsPercentage %>%): -<%= invoice.tdsDetails.tdsAmount %></p>
            <% } %>
            <p class="grand-total">Amount Due: <%= invoice.amountDue %></p>
        </div>
        
        <div style="margin-top: 50px;">
            <p><strong>Terms and Conditions</strong><br><%= invoice.termsAndConditions %></p>
        </div>
    </div>
</body>
</html>
